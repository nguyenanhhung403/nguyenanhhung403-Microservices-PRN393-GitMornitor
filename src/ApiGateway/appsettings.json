{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/teachers/{**catch-all}"
        }
      },
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "classroom-route": {
        "ClusterId": "classroom-cluster",
        "Match": {
          "Path": "/api/classrooms/{**catch-all}"
        }
      },
      "students-route": {
        "ClusterId": "classroom-cluster",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        }
      },
      "classroom-swagger-route": {
        "ClusterId": "classroom-cluster",
        "Match": {
          "Path": "/swagger/classroom/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "monitoring-dashboard-route": {
        "ClusterId": "monitoring-cluster",
        "Match": {
          "Path": "/api/dashboard/{**catch-all}"
        }
      },
      "monitoring-sync-route": {
        "ClusterId": "monitoring-cluster",
        "Match": {
          "Path": "/api/sync/{**catch-all}"
        }
      },
      "monitoring-sync-history-route": {
        "ClusterId": "monitoring-cluster",
        "Match": {
          "Path": "/api/sync-history/{**catch-all}"
        }
      },
      "monitoring-swagger-route": {
        "ClusterId": "monitoring-cluster",
        "Match": {
          "Path": "/swagger/monitoring/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5051/" }
        }
      },
      "classroom-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5020/" }
        }
      },
      "monitoring-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5039/" }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:02:00"
        }
      }
    }
  }
}
